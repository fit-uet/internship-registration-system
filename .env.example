# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GOOGLE_CLIENT_ID: Required for Google Sign-In on the frontend
# Users must create this in Google Cloud Console
VITE_GOOGLE_CLIENT_ID=""

# ADMIN_EMAIL: Optional admin email that skips the @vnu.edu.vn check
ADMIN_EMAIL="tuyenkv2112@gmail.com"

