# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GOOGLE_CLIENT_ID: Required for Google Sign-In on the frontend
# Users must create this in Google Cloud Console
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
VITE_API_BASE_URL="https://your-render-service.onrender.com"
# When using Cloudflare Workers instead of Render:
# VITE_API_BASE_URL="https://internship-api.<your-subdomain>.workers.dev"

# ADMIN_EMAIL: Optional admin email that skips the @vnu.edu.vn check
ADMIN_EMAIL="admin@example.com"

# Turso database connection for the API server
TURSO_DATABASE_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Required in production
JWT_SECRET="generate-a-long-random-secret"
CORS_ORIGIN="https://fit-uet.github.io"
